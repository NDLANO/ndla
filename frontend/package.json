{
  "name": "@ndla/frontend-workspace",
  "private": true,
  "description": "NDLA frontend monorepo workspace (packages + apps + graphql-api)",
  "license": "GPL-3.0",
  "author": "ndla@knowit.no",
  "workspaces": [
    "packages",
    "packages/packages/*",
    "ndla-frontend",
    "editorial-frontend",
    "graphql-api"
  ],
  "scripts": {
    "prepare": "yarn workspace @ndla/preset-panda run prepare",
    "build:packages": "yarn prepare && nx run-many -t build prepublish --exclude=ndla-frontend,editorial-frontend,ndla-graphql-api",
    "graph": "nx graph"
  },
  "devDependencies": {
